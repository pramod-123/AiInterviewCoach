# Copy to `.env` in this folder (`server/`). Only the HTTP bind address is configured here.
#
# All API keys, model ids, evaluation settings, and optional Whisper / voice-bridge fields live in
# `.app-runtime-config.json` (same directory as this file). Copy from `.app-runtime-config.example.json`
# or rely on `.app-runtime-config.defaults.json` for UI preset lists. Never commit `.env` or
# `.app-runtime-config.json`.
#
# Base URL for clients: http://HOST:PORT

HOST=127.0.0.1
PORT=3001
