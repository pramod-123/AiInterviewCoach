# Optional. The server does not load this file — configure the API with
# `server/.app-runtime-config.json` (Chrome → Server config) including optional:
#   listenHost, listenPort, databaseUrl (LibSQL / Prisma), API keys, llmProvider, …
#
# You may still export variables in your shell or keep this file for tools that read it
# (e.g. `npx prisma` without our config, or shell shortcuts that grep PORT= here).
#
# Example exports:
#   export PORT=3001
#   export HOST=127.0.0.1
#   export DATABASE_URL="file:./data/app.db"
